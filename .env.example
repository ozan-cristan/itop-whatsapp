# ── Meta WhatsApp Business API ──────────────────────────────────────────────
# Token de acceso permanente (Meta Developers → App → WhatsApp → API Setup)
WHATSAPP_TOKEN=

# ID del número de teléfono registrado en WhatsApp Business
PHONE_NUMBER_ID=

# Token que vos definís para verificar el webhook en Meta Developers
VERIFY_TOKEN=mi_token_secreto

# Puerto en el que escucha el servidor HTTP (default: 3000)
PORT=3000

# ── iTop REST API ────────────────────────────────────────────────────────────
ITOP_URL=https://itop.ejemplo.com
ITOP_USER=api_user
ITOP_TOKEN=api_token_aqui

# Secreto compartido para autenticar las notificaciones entrantes de iTop (POST /itop-notify).
# Debe coincidir con el header X-iTop-Secret que envía el webhook de iTop. Vacío = sin validación.
ITOP_WEBHOOK_SECRET=

# ── Bot ──────────────────────────────────────────────────────────────────────
# URL del documento de políticas de garantía (opción del menú). Vacío = opción no disponible.
GARANTIA_URL=
