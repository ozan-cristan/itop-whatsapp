# ── Meta WhatsApp Business API ──────────────────────────────────────────────
# Token de acceso permanente (Meta Developers → App → WhatsApp → API Setup)
WHATSAPP_TOKEN=

# ID del número de teléfono registrado en WhatsApp Business
PHONE_NUMBER_ID=

# Token que vos definís para verificar el webhook en Meta Developers
VERIFY_TOKEN=mi_token_secreto

# Puerto en el que escucha el servidor HTTP (default: 3000)
PORT=3000

# ── iTop REST API ────────────────────────────────────────────────────────────
ITOP_URL=https://itop.ejemplo.com
ITOP_USER=api_user
ITOP_TOKEN=api_token_aqui
ITOP_ORG=1
